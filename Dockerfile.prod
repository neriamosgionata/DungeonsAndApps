FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY backend/target/aarch64-unknown-linux-gnu/release/dungeonsandapps /usr/local/bin/dungeonsandapps

RUN chmod +x /usr/local/bin/dungeonsandapps

EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/dungeonsandapps"]
