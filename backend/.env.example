DATABASE_URL=postgres://cinghiale:cinghiale@localhost:5432/dungeonsandapps
JWT_SECRET=dev-jwt-secret-32-bytes-minimum-required
CORS_ORIGIN=*
BIND_ADDR=0.0.0.0:8080
RUST_LOG=info,dungeonsandapps=debug

S3_ENDPOINT=http://localhost:9000
S3_BUCKET=dungeonsandapps
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=eu-central-1
# Proxy endpoint that serves S3 files through the app (hides bucket URL, avoids 403)
# Production: set to https://your-api-domain/api/v1/files
S3_PUBLIC_URL=http://localhost:8080/api/v1/files

ADMIN_EMAIL="admin@dungeonsandapps.local"
ADMIN_PASSWORD="admin123456789!"
